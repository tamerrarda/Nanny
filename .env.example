# ─── Chain (Monad Testnet, chain ID 10143) ───────────────────────────────
MONAD_RPC_URL="https://testnet-rpc.monad.xyz"
NEXT_PUBLIC_CHAIN_ID="10143"
NEXT_PUBLIC_NANNY_VAULT_ADDRESS=""   # filled in after Step 3 deploy

# ─── Deploy ──────────────────────────────────────────────────────────────
# Do NOT put a raw private key here. Use a Foundry keystore instead:
#   cast wallet import nanny-deployer --interactive
#   forge script ... --account nanny-deployer --broadcast

# ─── Agent (LLM) ─────────────────────────────────────────────────────────
# Server-side only. Never expose to the client (no NEXT_PUBLIC_ prefix).
# Two ways to reach the model; set ONE. The route picks based on what is set.
#
# 1) Free, no credit card — Google AI Studio (https://aistudio.google.com/apikey).
#    Free tier is the Flash models; 1,500 req/day, 15 req/min. Note Google may
#    train on free-tier prompts.
GOOGLE_GENERATIVE_AI_API_KEY=""
#
# 2) Vercel AI Gateway — failover, spend tracking, one key for every provider.
#    Better long term, but it will not serve a single request until the team has
#    a card on file, free credits included. Auth is either this key or an OIDC
#    token from `vercel link && vercel env pull .env.local`.
AI_GATEWAY_API_KEY=""
#
# With the Google key: a bare id, e.g. "gemini-3.1-flash-lite".
# With the gateway:    "provider/model", e.g. "google/gemini-3-flash".
# Verify any id against your own key first — the free tier is narrower than the
# docs suggest, and models.list returns ids the key cannot actually call.
AGENT_MODEL=""

# ─── Agent wallet ────────────────────────────────────────────────────────
# The agent signs autonomously, so it holds its own key. Demo-grade only.
AGENT_PRIVATE_KEY=""
NEXT_PUBLIC_AGENT_ADDRESS=""         # public address of AGENT_PRIVATE_KEY

# ─── Owner wallet ────────────────────────────────────────────────────────
# There isn't one. Owners connect their own wallet and sign create/deposit/
# freeze themselves, so each vault's on-chain owner is the person who opened it.
# A server-held owner key would make every vault share one owner, and the
# contract's onlyOwner check would then let any visitor freeze anyone's vault.
