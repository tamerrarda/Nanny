# ─── Chain (Monad Testnet, chain ID 10143) ───────────────────────────────
MONAD_RPC_URL="https://testnet-rpc.monad.xyz"
NEXT_PUBLIC_CHAIN_ID="10143"
NEXT_PUBLIC_NANNY_VAULT_ADDRESS=""   # filled in after Step 3 deploy

# ─── Deploy ──────────────────────────────────────────────────────────────
# Do NOT put a raw private key here. Use a Foundry keystore instead:
#   cast wallet import nanny-deployer --interactive
#   forge script ... --account nanny-deployer --broadcast

# ─── Agent (LLM) ─────────────────────────────────────────────────────────
# Server-side only. Never expose to the client (no NEXT_PUBLIC_ prefix).
AI_GATEWAY_API_KEY=""
AGENT_MODEL=""                       # e.g. "<provider>/<model>" — chosen empirically in Step 5

# ─── Agent wallet ────────────────────────────────────────────────────────
# The agent signs autonomously, so it holds its own key. Demo-grade only.
AGENT_PRIVATE_KEY=""

# ─── Owner wallet (Para embedded wallet) ─────────────────────────────────
NEXT_PUBLIC_PARA_API_KEY=""
